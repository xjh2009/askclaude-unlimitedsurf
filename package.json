{
  "name": "askclaude-unlimitedsurf",
  "version": "0.1.0",
  "description": "MCP server exposing a read-only Ask Claude tool through Unlimited Surf with automatic model fallback.",
  "type": "module",
  "bin": {
    "askclaude-unlimitedsurf": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "dotenv": "^17.4.2",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
